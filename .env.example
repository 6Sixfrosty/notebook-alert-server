APP_ENV=development
LOG_LEVEL=INFO
APP_NAME="Alerta dos Notebooks"
APP_VERSION=1.0.0

API_TOKEN="<replace-with-api-token>"
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority"
DATABASE_NAME=alerta_dos_notebooks

# Optional integrations, not required by the server base configuration yet.
BREVO_API_KEY="<optional-brevo-api-key>"
TELEGRAM_API_HASH="<optional-telegram-api-hash>"
